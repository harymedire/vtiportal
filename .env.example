# ========================================
# VTIportal.com — environment varijable
# ========================================
# Kopiraj ovaj fajl u `.env` i popuni sa pravim vrijednostima.
# NE commit-uj .env u git!

# ===== LLM API-ji =====
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
OPENAI_API_KEY=sk-xxxxx
REPLICATE_API_TOKEN=r8_xxxxx

# ===== Modeli (default vrijednosti su OK) =====
CLAUDE_MODEL=claude-sonnet-4-6
IMAGE_MODEL=black-forest-labs/flux-schnell
EMBEDDING_MODEL=text-embedding-3-small

# ===== Baza (Supabase Transaction pooler, port 6543) =====
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ===== Redis (Celery broker) =====
# Lokalno: redis://localhost:6379/0
# Railway: popuni sa internim Railway Redis URL-om
REDIS_URL=redis://localhost:6379/0

# ===== Cloudflare R2 (S3-compatible storage za slike) =====
R2_ACCOUNT_ID=xxxxx
R2_ACCESS_KEY_ID=xxxxx
R2_SECRET_ACCESS_KEY=xxxxx
R2_BUCKET_NAME=vtiportal-images
R2_PUBLIC_URL=https://cdn.vtiportal.com

# ===== Telegram alerti =====
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# ===== Facebook Graph API (opciono) =====
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_AUTO_POST_ENABLED=false

# ===== Portal =====
PORTAL_BASE_URL=https://vtiportal.com
REVALIDATE_SECRET=generisi-random-dugacak-string-ovdje
ARTICLES_PER_DAY=20
TIMEZONE=Europe/Sarajevo

# ===== Monitoring (opciono) =====
SENTRY_DSN=
